# CrewCast environment variables
# Copy this file to .env and fill in your values

# Set to "false" to run the browser in headed (visible) mode
HEADLESS=true

# Optional: absolute path to CV file (overrides auto-detection from profile directory)
# CV_FILE=/absolute/path/to/cv.pdf

# Optional: absolute path to photo file (overrides auto-detection from profile directory)
# PHOTO_FILE=/absolute/path/to/photo.jpg

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Required when running src/bot/index.ts
# Obtain from @BotFather on Telegram: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=123456789:AABBCCddEEFFggHHiiJJ-example
